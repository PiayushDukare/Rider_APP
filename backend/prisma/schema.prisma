// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id // Firebase UID
  email       String?  @unique
  phone       String?  @unique
  handle      String?  @unique // e.g., @NightRider99
  displayName String?
  bikeModel   String?  // e.g., "Yamaha MT-07"
  bio         String?
  createdAt   DateTime @default(now())

  // Relations
  sentFriendRequests     Friendship[]  @relation("Requester")
  receivedFriendRequests Friendship[]  @relation("Addressee")
  sentInvites            RideInvite[]  @relation("Inviter")
  receivedInvites        RideInvite[]  @relation("Invitee")
  deviceTokens           DeviceToken[]
  rides                  RideSession[]
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   // "android" or "ios"
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Friendship {
  id          String       @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  requester   User @relation("Requester", fields: [requesterId], references: [id])
  addressee   User @relation("Addressee", fields: [addresseeId], references: [id])
  
  @@unique([requesterId, addresseeId])
}

model Room {
  id        String       @id @default(uuid())
  name      String       @unique // e.g., "PUNE NIGHT RIDERS"
  ownerId   String
  createdAt DateTime     @default(now())
  
  invites   RideInvite[]
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model RideInvite {
  id          String       @id @default(uuid())
  roomId      String
  inviterId   String
  inviteeId   String
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  room        Room @relation(fields: [roomId], references: [id])
  inviter     User @relation("Inviter", fields: [inviterId], references: [id])
  invitee     User @relation("Invitee", fields: [inviteeId], references: [id])
}

model RideSession {
  id           String         @id @default(uuid())
  riderId      String
  startTime    DateTime
  endTime      DateTime?
  distanceKm   Float
  privacyState String         @default("PRIVATE") // PRIVATE, SQUAD, PUBLIC
  routeJson    String?        // Compressed GeoJSON LineString
  
  user         User           @relation(fields: [riderId], references: [id])
  events       ConvoyEvent[]
}

model ConvoyEvent {
  id        String   @id @default(uuid())
  rideId    String
  type      String   // STOP, RECONNECT, SPLIT, HIGH_SPEED
  lat       Float
  lng       Float
  timestamp DateTime

  ride      RideSession @relation(fields: [rideId], references: [id])
}
